# ─────────────────────────────────────────────────────────────────
# GrowthMate Environment Variables
# Copy this file to apps/web/.env.local for local development.
# In Vercel, add the production values in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# ─── DATABASE ────────────────────────────────────────────────────
# Local development (SQLite):
#   DATABASE_URL="file:../../../packages/database/prisma/dev.db"
#
# Production (Turso / libSQL):
#   DATABASE_URL="libsql://<your-database>.turso.io"
DATABASE_URL=

# ─── DATABASE AUTH (Turso production only) ────────────────────────
DATABASE_AUTH_TOKEN=

# ─── SESSION COOKIE SECRET ──────────────────────────────────────
# Must be at least 32 random characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
